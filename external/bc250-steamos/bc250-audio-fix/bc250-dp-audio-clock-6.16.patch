 }
--- a/drivers/gpu/drm/amd/display/dc/clk_mgr/clk_mgr.c
+++ b/drivers/gpu/drm/amd/display/dc/clk_mgr/clk_mgr.c
@@ -253,6 +253,15 @@
 			BREAK_TO_DEBUGGER();
 			return NULL;
 		}
+		/* DCN 2.01 (Cyan Skillfish/BC-250) must be checked before the
+		 * Beige Goby rev range below, which is open-ended and matches
+		 * Cyan Skillfish's 0x82+ internal rev. Backport of upstream
+		 * commit 9c7be0efa6f0 ("drm/amd: fix dcn 2.01 check").
+		 */
+		if (ctx->dce_version == DCN_VERSION_2_01) {
+			dcn201_clk_mgr_construct(ctx, clk_mgr, pp_smu, dccg);
+			return &clk_mgr->base;
