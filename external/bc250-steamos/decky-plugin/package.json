{
  "name": "bc250-control",
  "version": "0.1.0",
  "description": "Big Picture controls for the BC-250 SteamOS toolkit",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "typecheck": "tsc --noEmit",
    "watch": "rollup -c -w"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keyboardspecialist/bc250-steamos.git",
    "directory": "decky-plugin"
  },
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/react-router": "5.1.20",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
